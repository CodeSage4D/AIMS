# ==============================================================================
# AURXON Intern Management System (AIMS) - Local Environment Configuration
# Copy this file to `.env` and fill in the values for local development.
# ==============================================================================

# 1. Database Connection (PostgreSQL)
# Standard connection string format. Works natively with Supabase, Neon, or local Postgres.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aurxon_aims?schema=public"

# 2. NextAuth Authentication Configuration
# Generate a secure 32-character key locally via: openssl rand -base64 32
NEXTAUTH_SECRET="your-32-character-nextauth-secret-key"
# Local host URL for guest redirects
NEXTAUTH_URL="http://localhost:3000"

# 3. Vercel Blob Storage Pipeline (Cloud CDN Assets)
# Retrieve this from your Vercel Dashboard -> Storage -> Blob
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_dummy_token_for_local_testing"
