datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider   = "prisma-client-js"
}

enum Role {
  FOUNDER
  SUPER_ADMIN
  ADMIN
  HR
  TEAM_LEAD
  INTERN
}

enum InternStatus {
  ACTIVE
  ONBOARDING
  COMPLETED
  TERMINATED
  ARCHIVED
  PENDING_VERIFICATION
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EmploymentType {
  INTERN
  PERMANENT
  CONTRACT
}


enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
  EMERGENCY_LEAVE
  HALF_DAY_1ST_HALF
  HALF_DAY_2ND_HALF
  WORK_PAUSED
  WORK_RESUMED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
}

enum DocType {
  OFFER_LETTER
  RESUME
  ID_PROOF
  AGREEMENT
  CERTIFICATE
  NDA
  EXPERIENCE_LETTER
}

model User {
  id                        String                 @id @default(uuid())
  email                     String                 @unique
  username                  String?                @unique
  passwordHash              String                 @map("password_hash")
  fullName                  String                 @map("full_name")
  role                      Role                   @default(INTERN)
  changePasswordRequired    Boolean                @default(false) @map("change_password_required")
  status                    UserStatus             @default(APPROVED)
  createdAt                 DateTime               @default(now()) @map("created_at")
  updatedAt                 DateTime               @updatedAt @map("updated_at")
  deletedAt                 DateTime?              @map("deleted_at")
  interns                   Intern[]               @relation("SupervisorRelation")
  tasks                     Task[]
  logs                      ActivityLog[]
  internProfile             Intern?                @relation("InternUserRelation")
  approvedDocuments         GeneratedDocument[]    @relation("ApprovedDocuments")
  createdEvents             Event[]                @relation("CreatedEvents")
  sentMessages              Message[]              @relation("SentMessages")
  receivedMessages          Message[]              @relation("ReceivedMessages")
  reviewedLeaves            LeaveApplication[]     @relation("ReviewedLeaves")
  updatedSettings           SystemSetting[]        @relation("SystemSettingsUpdatedBy")
  permission                UserPermission?
  createdGroups             ChatGroup[]            @relation("CreatedGroups")
  groupMemberships          GroupMember[]
  permissionChangesMade     PermissionChangeLog[]  @relation("PermissionChangesMade")
  permissionChangesReceived PermissionChangeLog[]  @relation("PermissionChangesReceived")

  @@map("users")
}

model Intern {
  id                     String           @id @default(uuid())
  internId               String           @unique @map("intern_id")
  fullName               String           @map("full_name")
  gender                 String
  dateOfBirth            DateTime         @map("date_of_birth")
  email                  String           @unique
  phoneNumber            String           @map("phone_number")
  address                String
  city                   String
  state                  String
  country                String
  pinCode                String?          @map("pin_code")
  citizenship            String?          @map("citizenship")
  region                 String?          @map("region")
  university             String           @map("university_college")
  degree                 String           @map("degree_course")
  department             String
  roleDomain             String           @map("role_domain")
  batchSemester          String           @map("batch_semester")
  startDate              DateTime         @map("start_date")
  endDate                DateTime?        @map("end_date")
  employmentType         EmploymentType   @default(INTERN) @map("employment_type")
  status                 InternStatus     @default(ONBOARDING)
  stipendAmount          Decimal          @default(0.00) @map("stipend_amount")
  paymentStatus          String           @default("UNPAID") @map("payment_status")
  documentStatus         String           @default("PENDING") @map("document_status")
  emergencyContactName   String           @map("emergency_contact_name")
  emergencyContactNumber String           @map("emergency_contact_number")
  skills                 String[]         @default([])
  performanceScore       Int?             @map("performance_score") // 1-5 Scale
  performanceNotes       String?          @map("performance_notes")
  notes                  String?          @map("notes")
  ssidn                  String?          @map("ssidn")
  bankName               String?          @map("bank_name")
  accountNumber          String?          @map("account_number")
  ifscCode               String?          @map("ifsc_code")
  upiId                  String?          @map("upi_id")
  branchName             String?          @map("branch_name")
  panCard                String?          @map("pan_card")
  supervisorId           String?          @map("supervisor_id")
  supervisor             User?            @relation("SupervisorRelation", fields: [supervisorId], references: [id], onDelete: SetNull)
  userId                 String?          @unique @map("user_id")
  user                   User?            @relation("InternUserRelation", fields: [userId], references: [id], onDelete: Cascade)
  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")
  deletedAt              DateTime?        @map("deleted_at")
  deletedBy              String?          @map("deleted_by")
  attendance             Attendance[]
  tasks                  Task[]
  documents              Document[]
  leaves                 LeaveApplication[]
  certificates           Certificate[]
  generatedDocuments     GeneratedDocument[]
  dailyLogs              DailyLog[]
  profileUpdateRequests  ProfileUpdateRequest[]
  events                 Event[]
  projectRecords         ProjectRecord[]

  @@index([fullName])
  @@index([status])
  @@index([internId])
  @@map("interns")
}

model Attendance {
  id                 String           @id @default(uuid())
  internId           String           @map("intern_id")
  intern             Intern           @relation(fields: [internId], references: [id], onDelete: Cascade)
  date               DateTime
  status             AttendanceStatus @default(PRESENT)
  checkIn            DateTime?        @map("check_in")
  checkOut           DateTime?        @map("check_out")
  breakDuration      Int              @default(0) @map("break_duration")
  totalWorkDuration  Int              @default(0) @map("total_work_duration")
  loginTimestamps    String[]         @default([]) @map("login_timestamps")
  activityTimestamps String[]         @default([]) @map("activity_timestamps")
  remarks            String?
  workSessions       WorkSession[]
  createdAt          DateTime         @default(now()) @map("created_at")

  @@unique([internId, date])
  @@map("attendance")
}

model Task {
  id                String     @id @default(uuid())
  internId          String     @map("intern_id")
  intern            Intern     @relation(fields: [internId], references: [id], onDelete: Cascade)
  title             String
  description       String
  deadline          DateTime
  status            TaskStatus @default(PENDING)
  assignedById      String?    @map("assigned_by_id")
  assigner          User?      @relation(fields: [assignedById], references: [id], onDelete: SetNull)
  remarks           String?
  submissionComment String?    @map("submission_comment")
  feedbackComment   String?    @map("feedback_comment")
  dailyLogs         DailyLog[]
  messages          Message[]
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  @@map("tasks")
}

model Document {
  id           String   @id @default(uuid())
  internId     String   @map("intern_id")
  intern       Intern   @relation(fields: [internId], references: [id], onDelete: Cascade)
  type         DocType
  fileName     String   @map("file_name")
  fileUrl      String   @map("file_url")
  verified     Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("documents")
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String
  description String
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("activity_logs")
}

model LeaveApplication {
  id           String    @id @default(uuid())
  internId     String    @map("intern_id")
  intern       Intern    @relation(fields: [internId], references: [id], onDelete: Cascade)
  startDate    DateTime  @map("start_date")
  endDate      DateTime  @map("end_date")
  type         String    @default("FULL_DAY") // FULL_DAY, HALF_DAY_1ST_HALF, HALF_DAY_2ND_HALF, URGENT_LEAVE, EMERGENCY_LEAVE, WORK_PAUSE, WORK_RESUME
  reason       String
  status       String    @default("PENDING") // PENDING, APPROVED, REJECTED
  requestTime  DateTime  @default(now()) @map("request_time")
  reviewedById String?   @map("reviewed_by_id")
  reviewedBy   User?     @relation("ReviewedLeaves", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNotes  String?   @map("review_notes")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("leave_applications")
}

model PasswordResetRequest {
  id           String    @id @default(uuid())
  internId     String    @map("intern_id")
  internName   String    @map("intern_name")
  internEmail  String    @map("intern_email")
  status       String    @default("PENDING") // PENDING, RESOLVED
  tempPassword String?   @map("temp_password")
  createdAt    DateTime  @default(now()) @map("created_at")
  resolvedAt   DateTime? @map("resolved_at")

  @@map("password_reset_requests")
}

model Certificate {
  id                String   @id @default(uuid())
  certificateId     String   @unique @map("certificate_id") // e.g. AXN-CERT-2026-XXXX
  verificationToken String   @unique @map("verification_token")
  holderName        String   @map("holder_name")
  internId          String?  @map("intern_id")
  intern            Intern?  @relation(fields: [internId], references: [id], onDelete: SetNull)
  type              String   // e.g. "INTERNSHIP_COMPLETION", "EXCELLENCE", "APPRECIATION"
  issueDate         DateTime @default(now()) @map("issue_date")
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("certificates")
}

model GeneratedDocument {
  id             String    @id @default(uuid())
  internId       String    @map("intern_id")
  intern         Intern    @relation(fields: [internId], references: [id], onDelete: Cascade)
  type           String    // e.g. "OFFER_LETTER", "NDA", "ID_CARD"
  content        Json      // Contains custom terms, template variables, or filled strings
  status         String    @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedById   String?   @map("approved_by_id")
  approvedBy     User?     @relation("ApprovedDocuments", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt     DateTime? @map("approved_at")
  signature      String?   // Cryptographic base64 signature hash or Admin/Founder signature stamp
  notes          String?   // Audit notes from founder review
  fileUrl        String?   @map("file_url") // Location of final generated document (PDF/Image)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("generated_documents")
}

model EmailLog {
  id           String   @id @default(uuid())
  recipient    String
  subject      String
  template     String   // e.g. "ONBOARDING_WELCOME", "TASK_ASSIGNED", "PASSWORD_RESET"
  status       String   @default("SENT") // SENT, FAILED
  errorMessage String?  @map("error_message")
  sentAt       DateTime @default(now()) @map("sent_at")

  @@map("email_logs")
}

model DailyLog {
  id            String   @id @default(uuid())
  internId      String   @map("intern_id")
  intern        Intern   @relation(fields: [internId], references: [id], onDelete: Cascade)
  date          DateTime @default(now())
  workCompleted String   @map("work_completed")
  blockers      String?
  hoursWorked   Decimal  @map("hours_worked")
  notes         String?
  taskId        String?  @map("task_id")
  task          Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("daily_logs")
}

model ProfileUpdateRequest {
  id            String   @id @default(uuid())
  internId      String   @map("intern_id")
  intern        Intern   @relation(fields: [internId], references: [id], onDelete: Cascade)
  fieldToUpdate String   @map("field_to_update")
  proposedValue String   @map("proposed_value")
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("profile_update_requests")
}

model WorkSession {
  id           String     @id @default(uuid())
  attendanceId String     @map("attendance_id")
  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  startTime    DateTime   @map("start_time")
  endTime      DateTime?  @map("end_time")
  isPaused     Boolean    @default(false) @map("is_paused")
  pauseReason  String?    @map("pause_reason")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@map("work_sessions")
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  type        String   @default("MEETING") // MEETING, DEADLINE, ONBOARDING, REMINDER, EVENT
  targetRole  String?  @map("target_role")  // Target role (e.g. "INTERN", "ALL")
  internId    String?  @map("intern_id")
  intern      Intern?  @relation(fields: [internId], references: [id], onDelete: Cascade)
  createdById String   @map("created_by_id")
  creator     User     @relation("CreatedEvents", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("events")
}

model Message {
  id         String     @id @default(uuid())
  content    String
  senderId   String     @map("sender_id")
  sender     User       @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String?    @map("receiver_id") // Null for general channel discussions or group chats
  receiver   User?      @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: SetNull)
  groupId    String?    @map("group_id")
  group      ChatGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  taskId     String?    @map("task_id")
  task       Task?      @relation(fields: [taskId], references: [id], onDelete: SetNull)
  isRead     Boolean    @default(false) @map("is_read")
  createdAt  DateTime   @default(now()) @map("created_at")

  @@map("messages")
}

model Holiday {
  id        String   @id @default(uuid())
  title     String
  date      DateTime @unique
  isCustom  Boolean  @default(false) @map("is_custom")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("holidays")
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   // JSON string of settings (e.g. weeklyOffs: [0, 6], halfDays: [5])
  updatedById String?  @map("updated_by_id")
  updatedBy   User?    @relation("SystemSettingsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model UserPermission {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dashboardAccess  Boolean  @default(true) @map("dashboard_access")
  attendanceAccess Boolean  @default(true) @map("attendance_access")
  taskAccess       Boolean  @default(true) @map("task_access")
  documentAccess   Boolean  @default(true) @map("document_access")
  approvalAccess   Boolean  @default(true) @map("approval_access")
  settingsAccess   Boolean  @default(true) @map("settings_access")
  analyticsAccess  Boolean  @default(true) @map("analytics_access")
  onboardingAccess Boolean  @default(true) @map("onboarding_access")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("user_permissions")
}

model ChatGroup {
  id          String        @id @default(uuid())
  name        String        @unique
  description String?
  createdById String        @map("created_by_id")
  creator     User          @relation("CreatedGroups", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  members     GroupMember[]
  messages    Message[]

  @@map("chat_groups")
}

model GroupMember {
  id        String    @id @default(uuid())
  groupId   String    @map("group_id")
  group     ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String    @default("MEMBER") // ADMIN, MEMBER
  createdAt DateTime  @default(now()) @map("created_at")

  @@unique([groupId, userId])
  @@map("group_members")
}

model PermissionChangeLog {
  id           String   @id @default(uuid())
  changedById  String   @map("changed_by_id")
  changedBy    User     @relation("PermissionChangesMade", fields: [changedById], references: [id], onDelete: Cascade)
  targetId     String   @map("target_id")
  target       User     @relation("PermissionChangesReceived", fields: [targetId], references: [id], onDelete: Cascade)
  previousRole String   @map("previous_role")
  newRole      String   @map("new_role")
  details      String?  // JSON string containing detailed permission overrides changed
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("permission_change_logs")
}

model ProjectRecord {
  id              String   @id @default(uuid())
  internId        String   @map("intern_id")
  intern          Intern   @relation(fields: [internId], references: [id], onDelete: Cascade)
  title           String
  description     String
  technologies    String[] @default([])
  roleInProject   String   @map("role_in_project")
  documentName    String?  @map("document_name")
  deliverableUrl  String?  @map("deliverable_url")
  status          String   @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, ARCHIVED
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("project_records")
}
