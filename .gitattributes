# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files that should always have LF line endings
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.prisma text eol=lf
*.css text eol=lf
*.md text eol=lf
*.html text eol=lf

# Denote binary/image files that must remain untouched
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.csv text eol=crlf
